@startuml SecondBrainLLD_v2
title Second Brain — Low Level Design v2
skinparam linetype ortho
skinparam rankdir TB
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classHeaderBackgroundColor #E6F1FB
skinparam classBorderColor #185FA5
skinparam arrowColor #185FA5
skinparam noteBackgroundColor #FAEEDA
skinparam noteBorderColor #BA7517
skinparam packageBackgroundColor #F1EFE8
skinparam packageBorderColor #888780
skinparam defaultFontName Helvetica

' ============================================================
' ENTITIES
' ============================================================
package "entities" {

  class User {
    - id : UUID <<PK>>
    - name : String
    - email : String <<unique>>
    - passwordHash : String
    - googleId : String
    - profilePictureUrl : String
    - timezone : String
    - createdAt : LocalDateTime
    - updatedAt : LocalDateTime
    --
    + toDto() : UserDto
  }

  class Domain {
    - id : UUID <<PK>>
    - userId : UUID <<FK>>
    - domainType : DomainType <<enum>>
    - customName : String
    - skillLevel : SkillLevel <<enum>>
    - status : DomainStatus <<enum>>
    - planDescription : String
    - weeklySchedule : String
    - linkedResourceUrl : String
    - linkedResourceTitle : String
    - currentStreak : Integer
    - longestStreak : Integer
    - lastLogDate : LocalDate
    - createdAt : LocalDateTime
    - updatedAt : LocalDateTime
    --
    + toDto() : DomainDto
    + isStreakBroken() : boolean
  }

  class DomainMetricDefinition {
    - id : UUID <<PK>>
    - domainId : UUID <<FK>>
    - metricKey : String
    - label : String
    - unit : String
    - isTrackedPerSession : boolean
    - isPR : boolean
    - isHigherBetter : boolean
    - displayOrder : Integer
    --
    + toDto() : MetricDefinitionDto
  }

  note right of DomainMetricDefinition
    All domains use this same table.
    GYM rows example:
      bench_press_kg / kg / isPR=true / higherBetter=true
      squat_kg       / kg / isPR=true / higherBetter=true
      deadlift_kg    / kg / isPR=true / higherBetter=true
      total_volume_kg/ kg / isPR=false
    RUNNING rows example:
      distance_km    / km  / isPR=true / higherBetter=true
      pace_per_km    / min / isPR=true / higherBetter=false
      elevation_m    / m   / isPR=false
    GUITAR rows example:
      practice_min   / min / isPR=false
      songs_completed/ num / isPR=false
    Zero domain-specific tables.
  end note

  class SessionLog {
    - id : UUID <<PK>>
    - userId : UUID <<FK>>
    - domainId : UUID <<FK>>
    - sessionType : String
    - logDate : LocalDate
    - durationMinutes : Integer
    - feelScore : Integer
    - feelLabel : FeelLabel <<enum>>
    - notes : String
    - linkedReferenceUrl : String
    - aiInsight : String
    - createdAt : LocalDateTime
    --
    + toDto() : SessionLogDto
  }

  note right of SessionLog
    notes = free text for any detail
    user wants — e.g. "4 sets bench:
    60/65/67.5/70kg". Not queried.
    aiInsight written async after save.
    No exerciseData column.
    No JSONB. No special gym handling.
  end note

  class SessionMetricValue {
    - id : UUID <<PK>>
    - sessionLogId : UUID <<FK>>
    - metricKey : String
    - numericValue : Double
    - unit : String
  }

  note right of SessionMetricValue
    One row per metric per session.
    Same table for every domain.
    GYM session rows:
      bench_press_kg  → 70.0
      bench_press_reps→ 8
      squat_kg        → 90.0
      squat_reps      → 5
      total_volume_kg → 3240
    RUNNING session rows:
      distance_km     → 5.2
      pace_per_km     → 6.32
      elevation_m     → 120
    Charts, PRs, weekly stats,
    milestones all read this table.
    Nothing else stores metric data.
  end note

  class PersonalRecord {
    - id : UUID <<PK>>
    - userId : UUID <<FK>>
    - domainId : UUID <<FK>>
    - sessionLogId : UUID <<FK>>
    - metricKey : String
    - value : Double
    - unit : String
    - achievedAt : LocalDate
    - previousValue : Double
    --
    + toDto() : PersonalRecordDto
  }

  note right of PersonalRecord
    One row per PR-trackable metric
    per domain. Upserted on each save.
    previousValue stored for delta
    display on celebration screen.
    Works identically for bench_press_kg,
    distance_km, pace_per_km — no
    exercise-specific fields.
  end note

  class Milestone {
    - id : UUID <<PK>>
    - domainId : UUID <<FK>>
    - label : String
    - metricKey : String
    - targetValue : Double
    - currentValue : Double
    - unit : String
    - status : MilestoneStatus <<enum>>
    - deadline : LocalDate
    - completedAt : LocalDate
    - aiGenerated : boolean
    - createdAt : LocalDateTime
    --
    + progressPercent() : Double
    + toDto() : MilestoneDto
  }

  class Task {
    - id : UUID <<PK>>
    - userId : UUID <<FK>>
    - domainId : UUID <<FK>>
    - title : String
    - description : String
    - status : TaskStatus <<enum>>
    - dueDate : LocalDate
    - completedAt : LocalDateTime
    - progress : Integer
    - aiGenerated : boolean
    - createdAt : LocalDateTime
    --
    + toDto() : TaskDto
  }

  class AiNudge {
    - id : UUID <<PK>>
    - userId : UUID <<FK>>
    - domainId : UUID <<FK>>
    - message : String
    - nudgeType : NudgeType <<enum>>
    - isRead : boolean
    - generatedAt : LocalDateTime
    - readAt : LocalDateTime
    --
    + toDto() : AiNudgeDto
  }

  note right of AiNudge
    Generated nightly by cron.
    One per domain per user per day max.
    Shown as a card on dashboard.
    MISSING_LOG: "Haven't logged gym
      in 3 days"
    STREAK_AT_RISK: "Log today or your
      12-day streak breaks tomorrow"
    PR_OPPORTUNITY: "You're 2.5kg away
      from a new bench PR"
    MILESTONE_CLOSE: "2km from your 5k
      distance milestone"
  end note

  class AiConversation {
    - id : UUID <<PK>>
    - userId : UUID <<FK>>
    - preview : String
    - createdAt : LocalDateTime
    - updatedAt : LocalDateTime
  }

  class AiMessage {
    - id : UUID <<PK>>
    - conversationId : UUID <<FK>>
    - role : MessageRole <<enum>>
    - content : String
    - createdAt : LocalDateTime
  }

  

  class RefreshToken {
    - id : UUID <<PK>>
    - userId : UUID <<FK>>
    - token : String <<unique>>
    - expiresAt : LocalDateTime
    - revokedAt : LocalDateTime
    --
    + isValid() : boolean
  }
}

' ============================================================
' ENUMS
' ============================================================
package "enums" {
  enum DomainType {
    GYM
    RUNNING
    READING
    GUITAR
    CHESS
    LANGUAGE
    NUTRITION
    SLEEP
    SWIMMING
    MEDITATION
    CUSTOM
  }
  enum SkillLevel {
    BEGINNER
    INTERMEDIATE
    ADVANCED
  }
  enum DomainStatus {
    ACTIVE
    PAUSED
    NEEDS_LOG
    COMPLETED_MILESTONE
    ARCHIVED
  }
  enum FeelLabel {
    STRONG
    OKAY
    TIRED
    ROUGH
  }
  enum MilestoneStatus {
    UPCOMING
    IN_PROGRESS
    DONE
    MISSED
  }
  enum TaskStatus {
    TODO
    IN_PROGRESS
    DONE
    SKIPPED
  }
  enum NudgeType {
    MISSING_LOG
    STREAK_AT_RISK
    PR_OPPORTUNITY
    REST_RECOMMENDED
    PLAN_ADJUST
    MILESTONE_CLOSE
    WEEKLY_SUMMARY
  }
  enum MessageRole {
    USER
    ASSISTANT
    SYSTEM
  }
}

' ============================================================
' DTO REQUEST
' ============================================================
package "dto_request" {
  class RegisterRequest {
    + name : String <<NotBlank>>
    + email : String <<Email>>
    + password : String <<Size(min=8)>>
  }
  class LoginRequest {
    + email : String <<Email>>
    + password : String <<NotBlank>>
  }
  class GoogleAuthRequest {
    + googleToken : String <<NotBlank>>
  }
  class RefreshTokenRequest {
    + refreshToken : String <<NotBlank>>
  }
  class CreateDomainRequest {
    + domainType : DomainType <<NotNull>>
    + customName : String
    + skillLevel : SkillLevel <<NotNull>>
    + linkedResourceUrl : String
  }
  class UpdateDomainRequest {
    + customName : String
    + skillLevel : SkillLevel
    + planDescription : String
    + weeklySchedule : String
    + linkedResourceUrl : String
    + status : DomainStatus
  }
  class CreateSessionLogRequest {
    + domainId : UUID <<NotNull>>
    + sessionType : String
    + logDate : LocalDate <<NotNull>>
    + durationMinutes : Integer
    + feelScore : Integer
    + feelLabel : FeelLabel
    + notes : String
    + linkedReferenceUrl : String
    + metrics : Map<String, Double> <<NotEmpty>>
  }
  note right of CreateSessionLogRequest
    metrics is a flat map.
    Keys must match DomainMetricDefinition
    metricKey values for this domain.
    Backend validates before save.
    GYM: {"bench_press_kg":70,
          "bench_press_reps":8,
          "squat_kg":90,"squat_reps":5}
    RUN: {"distance_km":5.2,
          "pace_per_km":6.32}
  end note
  class CreateTaskRequest {
    + domainId : UUID
    + title : String <<NotBlank>>
    + description : String
    + dueDate : LocalDate
  }
  class UpdateTaskStatusRequest {
    + status : TaskStatus <<NotNull>>
    + progress : Integer
  }
  class CreateMilestoneRequest {
    + domainId : UUID <<NotNull>>
    + label : String <<NotBlank>>
    + metricKey : String <<NotBlank>>
    + targetValue : Double <<NotNull>>
    + unit : String
    + deadline : LocalDate
  }
  class AiChatRequest {
    + message : String <<NotBlank>>
    + conversationId : UUID
  }
  class ApplyAiActionRequest {
    + actionType : String <<NotBlank>>
    + payload : Map<String, Object>
  }
  class UpdateProfileRequest {
    + name : String
    + timezone : String
  }
  
}

' ============================================================
' DTO RESPONSE
' ============================================================
package "dto_response" {
  class AuthResponse {
    + accessToken : String
    + refreshToken : String
    + user : UserDto
  }
  class UserDto {
    + id : UUID
    + name : String
    + email : String
    + profilePictureUrl : String
    + timezone : String
  }
  class DomainDto {
    + id : UUID
    + domainType : DomainType
    + customName : String
    + skillLevel : SkillLevel
    + status : DomainStatus
    + planDescription : String
    + weeklySchedule : String
    + linkedResourceUrl : String
    + linkedResourceTitle : String
    + currentStreak : Integer
    + longestStreak : Integer
    + lastLogDate : LocalDate
    + metrics : List<MetricDefinitionDto>
    + nextMilestone : MilestoneDto
  }
  class MetricDefinitionDto {
    + metricKey : String
    + label : String
    + unit : String
    + isTrackedPerSession : boolean
    + isPR : boolean
    + isHigherBetter : boolean
    + displayOrder : Integer
  }
  class SessionLogDto {
    + id : UUID
    + domainId : UUID
    + sessionType : String
    + logDate : LocalDate
    + durationMinutes : Integer
    + feelScore : Integer
    + feelLabel : FeelLabel
    + notes : String
    + linkedReferenceUrl : String
    + metrics : Map<String, Double>
    + aiInsight : String
    + newPrs : List<PersonalRecordDto>
  }
  note right of SessionLogDto
    metrics hydrated from
    SessionMetricValue rows on read.
    newPrs only populated on POST
    response. Empty on GET.
  end note
  class PersonalRecordDto {
    + metricKey : String
    + label : String
    + value : Double
    + unit : String
    + achievedAt : LocalDate
    + previousValue : Double
    + delta : Double
  }
  class MilestoneDto {
    + id : UUID
    + label : String
    + metricKey : String
    + targetValue : Double
    + currentValue : Double
    + unit : String
    + progressPercent : Double
    + status : MilestoneStatus
    + deadline : LocalDate
    + completedAt : LocalDate
  }
  class TaskDto {
    + id : UUID
    + domainId : UUID
    + title : String
    + description : String
    + status : TaskStatus
    + dueDate : LocalDate
    + progress : Integer
    + aiGenerated : boolean
  }
  class DashboardResponse {
    + greeting : String
    + date : LocalDate
    + todayFocus : List<TaskDto>
    + streaks : Map<UUID, StreakDto>
    + weeklyStats : List<WeeklyStatDto>
    + aiNudge : AiNudgeDto
    + upcomingTasks : List<TaskDto>
  }
  class StreakDto {
    + domainId : UUID
    + domainName : String
    + currentStreak : Integer
    + longestStreak : Integer
    + lastLogDate : LocalDate
  }
  class WeeklyStatDto {
    + domainId : UUID
    + domainName : String
    + metricKey : String
    + label : String
    + value : Double
    + target : Double
    + unit : String
  }
  class AiNudgeDto {
    + id : UUID
    + message : String
    + nudgeType : NudgeType
    + domainId : UUID
    + domainName : String
  }
  class AiChatResponse {
    + reply : String
    + conversationId : UUID
    + proposedActions : List<AiActionDto>
  }
  class AiActionDto {
    + type : String
    + description : String
    + payload : Map<String, Object>
  }
  note right of AiActionDto
    type values:
      ADJUST_PLAN
      ADD_TASK
      SET_MILESTONE
      LINK_RESOURCE
      UPDATE_SCHEDULE
    User confirms before applying.
  end note
  class AiConversationDto {
    + id : UUID
    + preview : String
    + updatedAt : LocalDateTime
  }
  class AiMessageDto {
    + id : UUID
    + role : MessageRole
    + content : String
    + createdAt : LocalDateTime
  }
  class ProgressResponse {
    + domainId : UUID
    + metricKey : String
    + timeSeries : List<TimeSeriesPointDto>
    + milestones : List<MilestoneDto>
    + prs : List<PersonalRecordDto>
  }
  class TimeSeriesPointDto {
    + date : LocalDate
    + value : Double
  }
  class GeneratedSystemDto {
    + planDescription : String
    + weeklySchedule : String
    + metrics : List<MetricDefinitionDto>
    + milestones : List<MilestoneDto>
    + linkedResourceUrl : String
    + linkedResourceTitle : String
    + tasks : List<TaskDto>
  }
  class ApiError {
    + status : Integer
    + message : String
    + errors : Map<String, String>
    + timestamp : LocalDateTime
  }
}

' ============================================================
' REPOSITORIES
' ============================================================
package "repositories" {
  interface UserRepository {
    + findByEmail(email: String) : Optional<User>
    + findByGoogleId(googleId: String) : Optional<User>
    + existsByEmail(email: String) : boolean
    + findAllIds() : List<UUID>
  }
  interface DomainRepository {
    + findByUserId(userId: UUID) : List<Domain>
    + findByUserIdAndDomainType(userId: UUID, type: DomainType) : Optional<Domain>
    + findByUserIdAndStatus(userId: UUID, status: DomainStatus) : List<Domain>
    + existsByUserIdAndDomainType(userId: UUID, type: DomainType) : boolean
    + findAllActiveForStreakCheck(today: LocalDate) : List<Domain>
  }
  interface DomainMetricDefinitionRepository {
    + findByDomainIdOrderByDisplayOrder(domainId: UUID) : List<DomainMetricDefinition>
    + findByDomainIdAndMetricKey(domainId: UUID, key: String) : Optional<DomainMetricDefinition>
    + findPrMetricsByDomainId(domainId: UUID) : List<DomainMetricDefinition>
    + deleteByDomainId(domainId: UUID) : void
  }
  interface SessionLogRepository {
    + findByUserIdOrderByLogDateDesc(userId: UUID, pageable: Pageable) : Page<SessionLog>
    + findByDomainIdOrderByLogDateDesc(domainId: UUID, pageable: Pageable) : Page<SessionLog>
    + findByDomainIdAndLogDateBetween(domainId: UUID, from: LocalDate, to: LocalDate) : List<SessionLog>
    + findTopNByDomainIdOrderByLogDateDesc(domainId: UUID, pageable: Pageable) : List<SessionLog>
    + findLogDatesByDomainId(domainId: UUID) : List<LocalDate>
    + countByDomainIdAndLogDateBetween(domainId: UUID, from: LocalDate, to: LocalDate) : Long
  }
  interface SessionMetricValueRepository {
    + findBySessionLogId(sessionLogId: UUID) : List<SessionMetricValue>
    + findBySessionLogIdIn(logIds: List<UUID>) : List<SessionMetricValue>
    + findMetricTimeSeries(domainId: UUID, metricKey: String, from: LocalDate, to: LocalDate) : List<TimeSeriesProjection>
    + findMaxValueForMetric(domainId: UUID, metricKey: String) : Optional<Double>
    + sumMetricForPeriod(domainId: UUID, metricKey: String, from: LocalDate, to: LocalDate) : Optional<Double>
  }
  note right of SessionMetricValueRepository
    findMetricTimeSeries JPQL:
    SELECT sl.logDate, smv.numericValue
    FROM SessionMetricValue smv
    JOIN smv.sessionLog sl
    WHERE sl.domain.id = :domainId
    AND smv.metricKey = :metricKey
    AND sl.logDate BETWEEN :from AND :to
    ORDER BY sl.logDate ASC
  end note
  interface PersonalRecordRepository {
    + findByDomainId(domainId: UUID) : List<PersonalRecord>
    + findByDomainIdAndMetricKey(domainId: UUID, metricKey: String) : Optional<PersonalRecord>
    + findByUserId(userId: UUID) : List<PersonalRecord>
    + findByUserIdOrderByAchievedAtDesc(userId: UUID, pageable: Pageable) : Page<PersonalRecord>
  }
  interface MilestoneRepository {
    + findByDomainId(domainId: UUID) : List<Milestone>
    + findByDomainIdAndStatus(domainId: UUID, status: MilestoneStatus) : List<Milestone>
    + findFirstByDomainIdAndStatusOrderByDeadlineAsc(domainId: UUID, status: MilestoneStatus) : Optional<Milestone>
    + findByDomainIdAndMetricKey(domainId: UUID, metricKey: String) : List<Milestone>
  }
  interface TaskRepository {
    + findByUserIdAndStatusIn(userId: UUID, statuses: List<TaskStatus>) : List<Task>
    + findByUserIdAndDueDateAndStatusIn(userId: UUID, date: LocalDate, statuses: List<TaskStatus>) : List<Task>
    + findByDomainId(domainId: UUID) : List<Task>
    + countByUserIdAndStatusAndDueDateBetween(userId: UUID, status: TaskStatus, from: LocalDate, to: LocalDate) : Long
  }
  interface AiNudgeRepository {
    + findFirstByUserIdAndIsReadFalseOrderByGeneratedAtDesc(userId: UUID) : Optional<AiNudge>
    + findByUserIdAndIsReadFalse(userId: UUID) : List<AiNudge>
    + existsByUserIdAndDomainIdAndGeneratedAtAfter(userId: UUID, domainId: UUID, since: LocalDateTime) : boolean
  }
  interface AiConversationRepository {
    + findByUserIdOrderByUpdatedAtDesc(userId: UUID) : List<AiConversation>
    + findByIdAndUserId(id: UUID, userId: UUID) : Optional<AiConversation>
  }
  interface AiMessageRepository {
    + findByConversationIdOrderByCreatedAtAsc(conversationId: UUID) : List<AiMessage>
    + findTop20ByConversationIdOrderByCreatedAtDesc(conversationId: UUID) : List<AiMessage>
  }
  
  interface RefreshTokenRepository {
    + findByToken(token: String) : Optional<RefreshToken>
    + deleteByUserId(userId: UUID) : void
    + deleteByExpiresAtBefore(cutoff: LocalDateTime) : void
  }
}

' ============================================================
' SERVICES
' ============================================================
package "services" {
  class AuthService {
    - userRepository : UserRepository
    - refreshTokenRepository : RefreshTokenRepository
    
    - jwtUtil : JwtUtil
    - passwordEncoder : PasswordEncoder
    - googleTokenVerifier : GoogleTokenVerifier
    --
    + register(request: RegisterRequest) : AuthResponse
    + login(request: LoginRequest) : AuthResponse
    + googleAuth(request: GoogleAuthRequest) : AuthResponse
    + refreshAccessToken(request: RefreshTokenRequest) : AuthResponse
    + logout(userId: UUID) : void
    - createRefreshToken(user: User) : RefreshToken
    - bootstrapUserDefaults(user: User) : void
    - buildAuthResponse(user: User) : AuthResponse
  }
  class DomainService {
    - domainRepository : DomainRepository
    - metricDefinitionRepository : DomainMetricDefinitionRepository
    - milestoneRepository : MilestoneRepository
    - taskRepository : TaskRepository
    - aiSystemGeneratorService : AiSystemGeneratorService
    --
    + getDomainsForUser(userId: UUID) : List<DomainDto>
    + getDomainById(domainId: UUID, userId: UUID) : DomainDto
    + createDomain(userId: UUID, request: CreateDomainRequest) : DomainDto
    + updateDomain(domainId: UUID, userId: UUID, request: UpdateDomainRequest) : DomainDto
    + pauseDomain(domainId: UUID, userId: UUID) : void
    + archiveDomain(domainId: UUID, userId: UUID) : void
    + generateAndApplySystem(domainId: UUID, userId: UUID) : GeneratedSystemDto
    + updateStreakForDomain(domain: Domain, logDate: LocalDate) : void
    + validateMetricKeys(domainId: UUID, submittedKeys: Set<String>) : void
    - applyGeneratedSystem(domain: Domain, generated: GeneratedSystemDto) : void
    - assertOwnership(domainId: UUID, userId: UUID) : Domain
  }
  note right of DomainService
    validateMetricKeys() called by
    SessionLogService before every save.
    Throws ValidationException if any
    submitted key is not defined in
    DomainMetricDefinition for domain.
    Prevents garbage data at entry point.
  end note
  class SessionLogService {
    - sessionLogRepository : SessionLogRepository
    - sessionMetricValueRepository : SessionMetricValueRepository
    - domainService : DomainService
    - prService : PersonalRecordService
    - milestoneService : MilestoneService
    - aiInsightService : AiInsightService
    --
    + createLog(userId: UUID, request: CreateSessionLogRequest) : SessionLogDto
    + getLogsForDomain(domainId: UUID, userId: UUID, pageable: Pageable) : Page<SessionLogDto>
    + getLogsForUser(userId: UUID, pageable: Pageable) : Page<SessionLogDto>
    + getLogById(logId: UUID, userId: UUID) : SessionLogDto
    + deleteLog(logId: UUID, userId: UUID) : void
    - persistMetricValues(log: SessionLog, metrics: Map<String, Double>) : void
    - hydrateMetrics(logId: UUID) : Map<String, Double>
    - buildDto(log: SessionLog, newPrs: List<PersonalRecordDto>) : SessionLogDto
  }
  note right of SessionLogService
    createLog() @Transactional steps:
    1. assertDomainOwnership
    2. validateMetricKeys
    3. save SessionLog
    4. bulk insert SessionMetricValues
    5. prService.checkAndUpdatePrs()
    6. milestoneService.updateProgress()
    7. domainService.updateStreak()
    8. aiInsightService.generate() @Async
    9. return dto with newPrs[]
    Steps 1-7 atomic. Step 8 async.
  end note
  class PersonalRecordService {
    - prRepository : PersonalRecordRepository
    - metricDefinitionRepository : DomainMetricDefinitionRepository
    --
    + checkAndUpdatePrs(log: SessionLog, metrics: Map<String, Double>) : List<PersonalRecordDto>
    + getPrsForDomain(domainId: UUID) : List<PersonalRecordDto>
    + getPrsForUser(userId: UUID, pageable: Pageable) : Page<PersonalRecordDto>
    - isBetter(newVal: Double, oldVal: Double, isHigherBetter: boolean) : boolean
    - upsertPr(log: SessionLog, metricKey: String, newVal: Double, unit: String, prevVal: Double) : PersonalRecordDto
  }
  note right of PersonalRecordService
    checkAndUpdatePrs():
    1. fetch isPR=true metrics for domain
    2. for each in session metrics map:
       - load existing PR (may be null)
       - compare via isBetter()
       - if better: upsert PR row,
         set previousValue = old value
    3. return new PRs list
    Identical logic for bench_press_kg,
    distance_km, pace_per_km, anything.
    No exercise-specific code paths.
  end note
  class MilestoneService {
    - milestoneRepository : MilestoneRepository
    - prRepository : PersonalRecordRepository
    - sessionMetricValueRepository : SessionMetricValueRepository
    --
    + createMilestone(userId: UUID, request: CreateMilestoneRequest) : MilestoneDto
    + getMilestonesForDomain(domainId: UUID) : List<MilestoneDto>
    + updateProgress(domainId: UUID) : void
    + getNextMilestone(domainId: UUID) : Optional<MilestoneDto>
    - resolveCurrentValue(milestone: Milestone) : Double
    - checkAndComplete(milestone: Milestone) : boolean
  }
  note right of MilestoneService
    resolveCurrentValue():
    if metricKey isPR=true
      → read PersonalRecord.value
    else
      → read latest SessionMetricValue
    Called after every log save.
    Auto-marks DONE when target hit.
  end note
  class TaskService {
    - taskRepository : TaskRepository
    - domainRepository : DomainRepository
    --
    + createTask(userId: UUID, request: CreateTaskRequest) : TaskDto
    + getTasksForUser(userId: UUID, statuses: List<TaskStatus>, domainId: UUID) : List<TaskDto>
    + getTodayTasks(userId: UUID) : List<TaskDto>
    + updateTaskStatus(taskId: UUID, userId: UUID, request: UpdateTaskStatusRequest) : TaskDto
    + deleteTask(taskId: UUID, userId: UUID) : void
    + bulkCreateFromAi(userId: UUID, tasks: List<TaskDto>) : List<TaskDto>
  }
  class DashboardService {
